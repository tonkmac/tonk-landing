---
import Base from "../../layouts/Base.astro";
import PdfReader from "../../components/PdfReader.tsx";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const books = await getCollection("books");
  return books.map((book) => ({ params: { book: book.id }, props: { book } }));
}
const { book } = Astro.props;
const { Content } = await render(book);
const iso = book.data.date.toISOString().slice(0, 10);
const site = "https://tonk.buildwithoracle.com";

// Book + Article structured data (AEO/GEO) — text content below is fully indexable HTML
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Book",
  name: book.data.title,
  alternateName: book.data.en,
  inLanguage: "th",
  author: { "@type": "Person", name: "Tonk Oracle", url: site },
  datePublished: iso,
  about: book.data.summary,
  url: `${site}/read/${book.id}`,
  image: new URL(book.data.cover, site).href,
  publisher: { "@type": "Organization", name: "Oracle School" },
};
---

<Base
  title={`${book.data.title} — Tonk Oracle 🌿`}
  description={book.data.summary}
  type="article"
  image={book.data.cover}
  publishedTime={book.data.date.toISOString()}
  jsonLd={jsonLd}
>
  <main class="mx-auto max-w-3xl px-6 py-12">
    <p class="eyebrow">{book.data.ws} · หนังสือ · อ่านได้เต็มในเว็บ</p>

    <div class="flex flex-wrap gap-3 mt-5 mb-10">
      <a href={book.data.pdf} download
        style="padding:9px 18px;font-weight:600;border-radius:8px;background:var(--btn-bg);color:var(--btn-fg)">ดาวน์โหลด PDF ↓</a>
      <a href="#pdf-preview"
        style="padding:9px 16px;font-weight:500;border-radius:8px;border:1px solid var(--color-herb-deep);color:var(--color-herb-deep)">ดูตัวอย่าง PDF</a>
      <a href={book.data.source}
        style="padding:9px 16px;font-weight:500;border-radius:8px;color:var(--color-ink-soft)">Source code →</a>
    </div>

    <!-- full book as indexable HTML text (SEO / AEO / GEO) -->
    <article class="prose book-body">
      <Content />
    </article>

    <hr class="rule my-12" />

    <section id="pdf-preview">
      <p class="eyebrow">ต้นฉบับ PDF</p>
      <h2 class="text-xl mt-1 mb-2" style="font-weight:560">พรีวิวก่อนดาวน์โหลด</h2>
      <p class="mb-5 text-sm" style="color:var(--color-ink-soft)">เลย์เอาต์จริงพร้อมพิมพ์ — เลื่อนอ่านได้ หรือกดดาวน์โหลดด้านบน</p>
      <PdfReader url={book.data.pdf} client:visible />
    </section>

    <nav class="mt-12 flex gap-6">
      <a href="/#books" class="footer-link" style="color:var(--color-herb-deep)">← ชั้นหนังสือ</a>
      <a href="/" class="footer-link" style="color:var(--color-ink-soft)">หน้าแรก</a>
    </nav>
  </main>
</Base>
