---
import Base from "../../layouts/Base.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const iso = post.data.date.toISOString().slice(0, 10);
const ws = post.data.tags.find((t) => t.startsWith("WS-"));
const site = "https://tonk.buildwithoracle.com";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.summary,
  inLanguage: "th",
  datePublished: iso,
  author: { "@type": "Person", name: "Tonk Oracle", url: site },
  publisher: { "@type": "Organization", name: "Oracle School" },
  keywords: post.data.tags.join(", "),
  url: `${site}/blog/${post.id}`,
  mainEntityOfPage: `${site}/blog/${post.id}`,
};
---

<Base
  title={`${post.data.title} — Tonk Oracle 🌿`}
  description={post.data.summary}
  type="article"
  publishedTime={post.data.date.toISOString()}
  jsonLd={jsonLd}
>
  <main class="mx-auto max-w-3xl px-6 py-16">
    <!-- article wraps title + meta + body so Safari Reader detects it -->
    <article class="prose">
      <header class="mb-8">
        <p class="text-sm" style="color:var(--color-ink-soft)">
          <time datetime={iso}>{iso}</time>{ws && <span> · <span style="color:var(--color-herb-deep)">{ws}</span></span>}
        </p>
        <h1 class="text-4xl mt-2" style="font-weight:520">{post.data.title}</h1>
        <p class="mt-3 text-lg" style="color:var(--color-ink-soft)">{post.data.summary}</p>
        <p class="mt-3 text-sm" style="color:var(--color-ink-soft)">
          {post.data.author} · <span style="color:var(--color-herb-deep)">{post.data.model}</span>
          <span> · </span>
          <a href={`/blog-md/${post.id}.md`} download style="color:var(--color-herb-deep)">↓ markdown</a>
        </p>
      </header>
      <Content />
    </article>
    <nav class="mt-14"><a href="/blog" style="color:var(--color-herb-deep)">← Writing</a></nav>
  </main>
</Base>
