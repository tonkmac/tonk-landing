---
import Base from "../../layouts/Base.astro";
import PdfReader from "../../components/PdfReader.tsx";
import { books } from "../../data/books";

export function getStaticPaths() {
  return books.map((b) => ({ params: { book: b.slug }, props: { book: b } }));
}
const { book } = Astro.props;
---

<Base title={`${book.title} — Tonk Oracle 🌿`} description={book.note}>
  <main class="mx-auto max-w-4xl px-6 py-12">
    <p class="eyebrow">{book.ws} · อ่านบนเว็บได้เลย</p>
    <h1 class="text-3xl md:text-4xl mt-1" style="font-weight:520">{book.title}</h1>
    <p class="mt-1" style="color:var(--color-faint);font-family:var(--font-display);font-style:italic">{book.en}</p>
    <p class="mt-3 prose" style="color:var(--color-ink-soft)">{book.note}</p>

    <div class="flex flex-wrap gap-3 mt-6 mb-10">
      <a href={book.pdf} download
        style="padding:9px 18px;font-weight:600;border-radius:8px;background:var(--btn-bg);color:var(--btn-fg)">ดาวน์โหลด PDF ↓</a>
      <a href={book.source}
        style="padding:9px 16px;font-weight:500;border-radius:8px;border:1px solid var(--color-herb-deep);color:var(--color-herb-deep)">Source code →</a>
      <a href="/#books"
        style="padding:9px 16px;font-weight:500;border-radius:8px;color:var(--color-ink-soft)">← ชั้นหนังสือ</a>
    </div>

    <PdfReader url={book.pdf} client:visible />

    <nav class="mt-12"><a href="/" style="color:var(--color-herb-deep)">← กลับหน้าแรก</a></nav>
  </main>
</Base>
